{
  "name": "server",
  "version": "1.0.0",
  "description": "BLE Attendance System Backend (PostgreSQL/Prisma)",
  "main": "index.js",
  "scripts": {
    "build": "npx prisma generate && npx prisma db push",
    "start": "node index.js",
    "start:cluster": "pm2 start index.js -i max --name ble-backend",
    "stop:cluster": "pm2 stop all",
    "dev": "nodemon index.js",
    "migrate": "node scripts/migrate-to-postgres.js",
    "db:push": "npx prisma db push",
    "db:indexes": "node scripts/add-indexes.js",
    "db:studio": "npx prisma studio"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.2.0",
    "multer": "^1.4.5-lts.2",
    "nanoid": "^3.3.11",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.9",
    "pg": "^8.20.0",
    "pm2": "^6.0.14",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.21.0"
  }
}
